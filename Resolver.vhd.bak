LIBRARY IEEE;
USE IEEE.STD_LOGIC_1164.ALL;
USE IEEE.numeric_std.ALL;

ENTITY RESOLVER IS
    PORT (
        CurrentFloor : IN INTEGER;
        Request : IN STD_LOGIC_VECTOR(9 DOWNTO 0);
        Direction : IN STD_LOGIC;
        TargetFloor : OUT INTEGER
    );
END RESOLVER;

ARCHITECTURE arch OF RESOLVER IS

BEGIN

    PROCESS (CurrentFloor, Request, Direction)
        VARIABLE FOUND : BOOLEAN := false;
    BEGIN
        FOUND := false;
        TargetFloor <= CurrentFloor; -- default value
        IF (Direction = '1' AND NOT(CurrentFloor = 9)) THEN
            FOR fl IN CurrentFloor + 1 TO 9 LOOP
                IF (Request(fl) = '1' AND NOT found) THEN
                    TargetFloor <= fl;
                    FOUND := true;
                END IF;
            END LOOP;
            IF (NOT FOUND) THEN
                FOR fl IN CurrentFloor - 1 DOWNTO 0 LOOP
                    IF (Request(fl) = '1' AND NOT found) THEN
                        TargetFloor <= fl;
                        FOUND := true;
                    END IF;
                END LOOP;
            END IF;
        ELSIF (Direction = '0' AND NOT(CurrentFloor = 0)) THEN
            FOR fl IN CurrentFloor - 1 DOWNTO 0 LOOP
                IF (Request(fl) = '1' AND NOT found) THEN
                    TargetFloor <= fl;
                    FOUND := true;
                END IF;
            END LOOP;
            IF (NOT FOUND) THEN
                FOR fl IN CurrentFloor + 1 TO 9 LOOP
                    IF (Request(fl) = '1' AND NOT found) THEN
                        TargetFloor <= fl;
                        FOUND := true;
                    END IF;
                END LOOP;
            END IF;
            -- ELSIF (NOT(Direction = '0') AND NOT(Direction = '1')) THEN
            --     FOR fl IN CurrentFloor + 1 TO 9 LOOP
            --         IF (Request(fl) = '1' AND NOT found) THEN
            --             TargetFloor <= fl;
            --             FOUND := true;
            --         END IF;
            --     END LOOP;
        END IF;
    END PROCESS;

END arch; -- arch